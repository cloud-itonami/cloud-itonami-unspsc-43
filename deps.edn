{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). Both
 ;; live in the kotoba-lang org of this workspace. This repo is
 ;; standalone (forkable outside the workspace); the :local/root paths
 ;; only resolve inside the monorepo checkout -- a standalone fork
 ;; should override them with git coordinates. langchain is pinned here
 ;; directly (not only under :dev) so a bare `clojure -M:test` works
 ;; offline inside the monorepo checkout without depending on
 ;; langgraph's own transitive git/sha pin being fetchable.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/langchain
        {:local/root "../../kotoba-lang/langchain"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  ;; (kept for parity with sibling actors' deps.edn shape; redundant
  ;; with the top-level :deps override above).
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "itad.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
